{
  "name": "ecolens",
  "version": "1.0.0",
  "description": "Lightweight CLI to optimize image URLs using Cloudinary fetch transformations",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "ecolens": "./dist/index.js"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "prepare": "npm run build"
